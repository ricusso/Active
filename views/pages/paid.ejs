<%- include('../partials/head', { title: 'Оплата успешна' }) %>
<style>
main { padding: 60px 20px; text-align: center; flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.success-card { background: var(--surface); border: 1px solid var(--border); padding: 48px; border-radius: 24px; max-width: 500px; width: 100%; box-shadow: 0 20px 50px rgba(0,0,0,0.3); animation: fadeInUp 0.6s ease both; }
.success-icon { width: 80px; height: 80px; background: rgba(110,231,160,0.1); color: var(--green); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 40px; margin-bottom: 24px; }
h1 { font-family: 'Inter', sans-serif; font-size: 28px; margin-bottom: 12px; }
p { color: var(--text2); margin-bottom: 32px; line-height: 1.6; }
.btn-go { background: var(--pink); color: #111; padding: 16px 32px; border-radius: 14px; font-weight: 900; text-decoration: none; transition: all 0.2s; }
.btn-go:hover { transform: translateY(-2px); box-shadow: 0 10px 20px rgba(14, 165, 233, 0.3); }
@keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
</style>
<body class="<%= user ? 'logged-in' : 'guest' %>">
<%- include('../partials/sidebar_mobile') %>
<%- include('../partials/sidebar_desktop') %>
<div class="page-wrap">
  <main>
    <div class="success-card">
      <div class="success-icon">✓</div>
      <h1>Оплачено!</h1>
      <p>Квест "<%= quest.title %>" успешно добавлен в ваши активные задачи. Начните свое приключение прямо сейчас!</p>
      <a href="/my-quests" class="btn-go">Перейти к квестам</a>
    </div>
  </main>
</div>
<script src="/js/scripts.js"></script>
</body>
</html>
