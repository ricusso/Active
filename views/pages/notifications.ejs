<%- include('../partials/head', { title: 'Уведомления' }) %>
<style>

main { flex: 1; padding: 32px 32px 56px; }

h1{font-family:'Inter', sans-serif;font-size:32px;margin-bottom:40px; background:linear-gradient(120deg,var(--text) 60%,var(--pink)); -webkit-background-clip:text; -webkit-text-fill-color:transparent;}

.notif-grid { max-width: 800px; }

.notif-item {
  background: var(--surface); border: 1px solid var(--border);
  padding: 24px; border-radius: 20px; margin-bottom: 16px;
  display: flex; gap: 20px; align-items: flex-start;
  transition: all 0.3s ease; position: relative; overflow: hidden;
}
.notif-item:hover { border-color: var(--pink); transform: translateX(5px); }
.notif-item::after { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, rgba(255,255,255,0.01) 0%, transparent 50%); pointer-events: none; }

.notif-ico {
  width: 48px; height: 48px; border-radius: 14px; background: var(--surface2);
  display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0;
  border: 1px solid var(--border);
}

.notif-content { flex: 1; }
.notif-content h3 { font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 700; margin-bottom: 6px; color: var(--text); }
.notif-content p { font-size: 14px; color: var(--text2); line-height: 1.6; }

.notif-meta { display: flex; justify-content: space-between; align-items: center; margin-top: 16px; }
.notif-time { font-size: 11px; color: var(--text3); font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
.notif-type { font-size: 10px; font-weight: 900; text-transform: uppercase; color: var(--pink); background: var(--pink-soft); padding: 2px 8px; border-radius: 4px; }

.empty-state { text-align: center; padding: 100px 20px; color: var(--text3); }

.blob { position: fixed; border-radius: 50%; filter: blur(90px); opacity: 0.1; z-index: 0; pointer-events: none; }
.blob-1 { width: 500px; height: 500px; background: var(--pink); top: -100px; right: -100px; }
</style>
<body class="<%= user ? 'logged-in' : 'guest' %>">
<div class="blob blob-1"></div>
<%- include('../partials/sidebar_mobile') %>
<%- include('../partials/sidebar_desktop') %><div class="page-wrap"><div class="topbar">
    <div class="topbar-left">
      <div class="breadcrumb">
        <a href="/"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>Платформа</a>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        <span>Уведомления</span>
      </div>
    </div>
  </div>

  <main>
    <h1>Ваши уведомления</h1>

    <div class="notif-grid">
      <% if (notifications.length > 0) { %>
        <% notifications.forEach(n => { %>
          <div class="notif-item">
            <div class="notif-ico">
              <% if(n.type === 'achievement') { %> 🏆
              <% } else if(n.type === 'message') { %> 💬
              <% } else { %> 🔔 <% } %>
            </div>
            <div class="notif-content">
              <h3><%= n.title %></h3>
              <p><%= n.message %></p>
              <div class="notif-meta">
                <span class="notif-time"><%= new Date(n.createdAt).toLocaleDateString('ru-RU') %></span>
                <span class="notif-type"><%= n.type %></span>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="empty-state">
          <p>У вас пока нет новых уведомлений</p>
        </div>
      <% } %>
    </div>
  </main>
</div>

<%- include('../partials/toast') %>
<script src="/js/scripts.js"></script>
</body>
</html>
