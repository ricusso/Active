<%- include('../partials/head', { title: 'Личный чат Актив' }) %>
<style>

main { flex: 1; display: flex; flex-direction: column; padding: 0; }

.chat-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  background: var(--bg);
}

.chat-header {
  padding: 20px 32px;
  background: rgba(22, 22, 28, 0.8);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.chat-messages {
  flex: 1;
  overflow-y: auto;
  padding: 32px;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.msg {
  max-width: 60%;
  padding: 16px 20px;
  border-radius: 20px;
  font-size: 14px;
  line-height: 1.6;
}

.msg.in {
  background: var(--surface);
  align-self: flex-start;
  border-bottom-left-radius: 4px;
  color: var(--text2);
  border: 1px solid var(--border);
}

.msg.out {
  background: var(--purple);
  color: #111;
  align-self: flex-end;
  border-bottom-right-radius: 4px;
  font-weight: 600;
}

.msg-time {
  font-size: 9px;
  opacity: 0.6;
  margin-top: 6px;
  display: block;
  text-align: right;
}

.chat-footer {
  padding: 24px 32px;
  background: var(--surface);
  border-top: 1px solid var(--border);
}

.input-area {
  display: flex;
  gap: 16px;
}

.chat-input {
  flex: 1;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 16px 24px;
  color: var(--text);
  font-family: inherit;
  outline: none;
}

.btn-send {
  width: 52px; height: 52px;
  border-radius: 16px;
  background: var(--purple);
  border: none;
  color: #111;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
}
</style>
<body class="<%= user ? 'logged-in' : 'guest' %>">

<%- include('../partials/sidebar_mobile') %>
<%- include('../partials/sidebar_desktop') %><div class="page-wrap"><div class="topbar">
    <div class="topbar-left">
      <div class="breadcrumb">
        <a href="/"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>Платформа</a>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        <span>Чат: <%= enrollment.Quest.title %></span>
      </div>
    </div>
  </div>

  <main>
    <div class="chat-container">
      <div class="chat-header">
        <div style="font-weight: 800;">Наставник квеста</div>
        <a href="/my-quests" style="color: var(--text3); text-decoration: none; font-size: 13px;">Назад</a>
      </div>

      <div class="chat-messages" id="chatMessages">
        <% if (messages.length > 0) { %>
          <% messages.forEach(m => { %>
            <div class="msg <%= m.senderRole === user.role ? 'out' : 'in' %>">
              <%= m.message %>
              <span class="msg-time"><%= new Date(m.createdAt).toLocaleTimeString('ru-RU', {hour: '2-digit', minute:'2-digit'}) %></span>
            </div>
          <% }) %>
        <% } else { %>
          <div style="text-align: center; color: var(--text3); margin-top: 40px;">История сообщений пуста</div>
        <% } %>
      </div>

      <div class="chat-footer">
        <form action="/chat/<%= enrollment.id %>/send" method="POST" class="input-area">
          <input type="text" name="message" class="chat-input" placeholder="Напишите сообщение..." required>
          <button type="submit" class="btn-send">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </form>
      </div>
    </div>
  </main>
</div>

<%- include('../partials/toast') %>
<script src="/js/scripts.js"></script>
<script>

  const chatMessages = document.getElementById('chatMessages');
  chatMessages.scrollTop = chatMessages.scrollHeight;
</script>
</body>
</html>
