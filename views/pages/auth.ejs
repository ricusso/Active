      </div>
      <div class="logo-text">АКТИВ</div>
    </div>

    <div class="error-banner" id="errorBanner">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <span id="errorMsg">Неверные данные</span>
    </div>

    <div class="form-toggle">
      <button class="toggle-btn active" id="btnJoin">Вход</button>
      <button class="toggle-btn" id="btnReg">Регистрация</button>
    </div>

    <form id="loginForm" class="fade-in" action="/auth/login" method="POST">
      <div class="form-group">
        <label>E-mail адрес</label>
        <div class="input-wrap">
          <input type="email" name="email" placeholder="name@domain.com" required>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
      </div>
      <div class="form-group">
        <label>Пароль</label>
        <div class="input-wrap">
          <input type="password" name="password" placeholder="••••••••" required>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
      </div>
      <button type="submit" class="btn-submit">Авторизоваться</button>
    </form>

    <form id="registerForm" action="/auth/register" method="POST">
      <div class="form-group">
        <label>Имя пользователя</label>
        <div class="input-wrap">
          <input type="text" name="name" placeholder="Gamer_One" required id="regName">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
      </div>
      <div class="form-group">
        <label>E-mail адрес</label>
        <div class="input-wrap">
          <input type="email" name="email" placeholder="name@domain.com" required id="regEmail">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
      </div>
      <div class="form-group">
        <label>Кто вы?</label>
        <div style="display:flex; gap:10px;">
          <label style="flex:1;">
            <input type="radio" name="role" value="user" checked style="display:none;">
            <div class="role-btn active" onclick="selectRole(this)">Пользователь</div>
          </label>
          <label style="flex:1;">
            <input type="radio" name="role" value="expert" style="display:none;">
            <div class="role-btn" onclick="selectRole(this)">Эксперт</div>
          </label>
        </div>
      </div>
      <div class="form-group">
        <label>Придумайте пароль</label>
        <div class="input-wrap">
          <input type="password" name="password" placeholder="••••••••" required id="regPass">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
      </div>
      <button type="submit" class="btn-submit">Начать путь</button>
    </form>

    <div class="social-auth">
      <div class="social-btn">
        <svg width="20" height="20" viewBox="0 0 48 48">
          <path fill="#FFC107" d="M43.611,20.083H42V20H24v8h11.303c-1.649,4.657-6.08,8-11.303,8c-6.627,0-12-5.373-12-12c0-6.627,5.373-12,12-12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C12.955,4,4,12.955,4,24c0,11.045,8.955,20,20,20c11.045,0,20-8.955,20-20C44,22.659,43.862,21.35,43.611,20.083z"></path>
          <path fill="#FF3D00" d="M6.306,14.691l6.571,4.819C14.655,15.108,18.961,12,24,12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C16.318,4,9.656,8.337,6.306,14.691z"></path>
          <path fill="#4CAF50" d="M24,44c5.166,0,9.86-1.977,13.409-5.192l-6.19-5.238C29.211,35.091,26.715,36,24,36c-5.202,0-9.619-3.317-11.283-7.946l-6.522,5.025C9.505,39.556,16.227,44,24,44z"></path>
          <path fill="#1976D2" d="M43.611,20.083H42V20H24v8h11.303c-0.792,2.237-2.231,4.166-4.087,5.571c0.001-0.001,0.002-0.001,0.003-0.002l6.19,5.238C36.971,39.205,44,34,44,24C44,22.659,43.862,21.35,43.611,20.083z"></path>
        </svg>
      </div>
      <div class="social-btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="#5865F2"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037 19.736 19.736 0 0 0-4.885 1.515.069.07 0 0 0-.032.027C.533 9.048-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.419-2.157 2.419zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.419-2.157 2.419z"/></svg>
      </div>
    </div>

    <div class="footer-links">
      <span id="footerText">Ещё нет аккаунта?</span>
      <a href="#" id="footerAction">Создать аккаунт</a>
    </div>
  </div>
</div>

<script>

  const btnJoin = document.getElementById('btnJoin');
  const btnReg = document.getElementById('btnReg');
  const loginForm = document.getElementById('loginForm');
  const registerForm = document.getElementById('registerForm');
  const footerText = document.getElementById('footerText');
  const footerAction = document.getElementById('footerAction');
  const errorBanner = document.getElementById('errorBanner');
  const errorMsg = document.getElementById('errorMsg');

  function showLogin() {
    btnJoin.classList.add('active');
    btnReg.classList.remove('active');
    loginForm.style.display = 'block';
    registerForm.style.display = 'none';
    loginForm.classList.add('fade-in');
    footerText.textContent = 'Ещё нет аккаунта?';
    footerAction.textContent = 'Создать аккаунт';
    errorBanner.style.display = 'none';
  }

  function showReg() {
    btnReg.classList.add('active');
    btnJoin.classList.remove('active');
    loginForm.style.display = 'none';
    registerForm.style.display = 'block';
    registerForm.classList.add('fade-in');
    footerText.textContent = 'Уже есть аккаунт?';
    footerAction.textContent = 'Войти в систему';
    errorBanner.style.display = 'none';
  }

  function selectRole(el) {
    document.querySelectorAll('.role-btn').forEach(b => b.classList.remove('active'));
    el.classList.add('active');
    el.parentElement.querySelector('input').checked = true;
  }

  btnJoin.addEventListener('click', showLogin);
  btnReg.addEventListener('click', showReg);
  footerAction.addEventListener('click', (e) => {
    e.preventDefault();
    if(loginForm.style.display === 'none') showLogin();
    else showReg();
  });

  const urlParams = new URLSearchParams(window.location.search);
  const error = urlParams.get('error');
  if (error) {
    errorBanner.style.display = 'flex';
    if (error === 'invalid_creds') errorMsg.textContent = 'Неверный email или пароль';
    if (error === 'reg_failed') errorMsg.textContent = 'Email уже занят или ошибка сервера';
    if (error === 'login_failed') errorMsg.textContent = 'Ошибка входа. Попробуйте позже';
  }
</script>

<%- include('../partials/toast') %>

<script src="/js/scripts.js"></script></body>
</html>
